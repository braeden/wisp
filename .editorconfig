root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
max_line_length = 100
ktlint_standard_trailing-comma-on-call-site = enabled
ktlint_standard_trailing-comma-on-declaration-site = enabled
# The codebase predates ktlint; a committed ktlint baseline grandfathers any
# existing rule violations so only new code is gated. Prefer the baseline over
# disabling rules here.

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
